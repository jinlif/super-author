{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "默认权限集",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://coding.dashscope.aliyuncs.com/**"
        },
        {
          "url": "https://api.anthropic.com/**"
        }
      ]
    }
  ],
  "remote": {
    "urls": [
      "https://*"
    ]
  }
}